vendor/stb/stb_image_impl.o: vendor/stb/stb_image_impl.cpp.o
.PHONY : vendor/stb/stb_image_impl.o

# target to build an object file
vendor/stb/stb_image_impl.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/stb_image.dir/build.make CMakeFiles/stb_image.dir/vendor/stb/stb_image_impl.cpp.o
.PHONY : vendor/stb/stb_image_impl.cpp.o

vendor/stb/stb_image_impl.i: vendor/stb/stb_image_impl.cpp.i
.PHONY : vendor/stb/stb_image_impl.i

# target to preprocess a source file
vendor/stb/stb_image_impl.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/stb_image.dir/build.make CMakeFiles/stb_image.dir/vendor/stb/stb_image_impl.cpp.i
.PHONY : vendor/stb/stb_image_impl.cpp.i

vendor/stb/stb_image_impl.s: vendor/stb/stb_image_impl.cpp.s
.PHONY : vendor/stb/stb_image_impl.s

# target to generate assembly for a file
vendor/stb/stb_image_impl.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/stb_image.dir/build.make CMakeFiles/stb_image.dir/vendor/stb/stb_image_impl.cpp.s
.PHONY : vendor/stb/stb_image_impl.cpp.s

